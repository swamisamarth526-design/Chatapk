# Environment (development or production)
# For Railway deployment, set to production
NODE_ENV=production

# Server Port
# Railway will set this automatically
PORT=5000

# MongoDB Connection
# Railway MongoDB instance
MONGODB_URI=mongodb://mongo:YHJTQxZtmrhBAqmlXRufSaTZMXUweJof@mongodb-joug.railway.internal:27017

# JWT Secret (REQUIRED for production)
# Generate a strong random string using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Example value (replace with your own generated secret):
JWT_SECRET=e4f7a2b9d1c6e3f8a5b2d7c4e9f1a6b3d8e5f2a9b6c1d8e5f2a7b4c9d6e3f0

# JWT Expiration
JWT_EXPIRE=7d

# CORS Configuration
# For production with frontend served from same domain
FRONTEND_URL=http://localhost:5173
# For Railway, set your actual frontend domain
FRONTEND_URLS=http://localhost:5173
